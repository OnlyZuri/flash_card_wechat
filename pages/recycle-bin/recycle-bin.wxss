/* 回收站页面样式 */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 提示信息 */
.tips {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: #fff;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.action-left,
.action-right {
  display: flex;
  gap: 16rpx;
}

.btn-batch,
.btn-restore {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  background: #f5f5f5;
  color: #666;
}

.btn-restore-main,
.btn-restore-small {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  background: #34C759;
  color: #fff;
}

.btn-restore-main[disabled],
.btn-restore-small[disabled] {
  background: #ccc;
}

.btn-delete-main,
.btn-delete-small {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  background: #FF3B30;
  color: #fff;
}

.btn-delete-main[disabled],
.btn-delete-small[disabled] {
  background: #ccc;
}

.btn-clear {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  background: #FF9500;
  color: #fff;
}

/* 回收站列表 */
.recycle-list {
  margin-top: 20rpx;
}

.recycle-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.item-checkbox {
  margin-right: 16rpx;
  padding-top: 8rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background: #007AFF;
  border-color: #007AFF;
}

.item-content {
  flex: 1;
  overflow: hidden;
}

.item-question {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.item-answer {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.delete-time {
  color: #999;
}

.remain-days {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
}

.remain-days.expired {
  background: #FFE5E5;
  color: #FF3B30;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-left: 16rpx;
}

.btn-restore-small,
.btn-delete-small {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 按钮禁用状态 */
button[disabled] {
  opacity: 0.5;
}
