/* 回收站页面样式 - 按过期时间分组 */
.container {
  min-height: 100vh;
  background-color: #F2F2F7;
  padding-bottom: 120rpx;
}

/* 顶部操作栏 */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.info-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.info-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
  transition: all 0.2s;
}

.action-btn.batch-cancel {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  box-shadow: 0 4rpx 12rpx rgba(245, 87, 108, 0.4);
}

.action-btn:active {
  transform: scale(0.95);
}

/* 批量工具栏 */
.batch-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin: 0 20rpx 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.batch-checkbox-all {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-label {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.batch-actions {
  display: flex;
  gap: 12rpx;
}

.batch-btn {
  padding: 14rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.batch-btn.restore {
  background: linear-gradient(135deg, #34C759 0%, #30B34D 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(52, 199, 89, 0.3);
}

.batch-btn.restore:active {
  transform: scale(0.95);
}

.batch-btn.delete {
  background: linear-gradient(135deg, #FF3B30 0%, #D70015 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 59, 48, 0.3);
}

.batch-btn.delete:active {
  transform: scale(0.95);
}

/* 分组列表 */
.grouped-list {
  padding: 0 20rpx;
}

/* 分组头部 */
.group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 12rpx 12rpx;
  margin-top: 20rpx;
}

.group-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.group-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.group-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.group-count {
  font-size: 26rpx;
  color: #8E8E93;
  background-color: #E5E5EA;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 分组卡片容器 */
.group-cards {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 卡片项 */
.card-item {
  position: relative;
  padding: 24rpx 24rpx 24rpx 24rpx;
  min-height: 100rpx;
  border-bottom: 1rpx solid #F2F2F7;
  transition: all 0.2s;
}

.card-item.batch-mode {
  padding-left: 80rpx;
}

.card-item:last-child {
  border-bottom: none;
}

.card-item.selected {
  background-color: #F0F7FF;
}

.card-item:active {
  background-color: #F8F8F8;
}

.card-item.selected:active {
  background-color: #E8F2FF;
}

/* 复选框 */
.card-checkbox {
  position: absolute;
  left: 16rpx;
  top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  z-index: 10;
}

.checkbox {
  width: 42rpx;
  height: 42rpx;
  border: 3rpx solid #C7C7CC;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  box-sizing: border-box;
  transition: all 0.2s;
}

.checkbox.checked {
  background-color: #007AFF;
  border-color: #007AFF;
}

.checkbox text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
}

/* 卡片内容 */
.card-content {
  flex: 1;
}

.card-question {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag-sm {
  display: inline-block;
  background: linear-gradient(135deg, #E8F4FD 0%, #F0F7FF 100%);
  color: #007AFF;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid #B3D9FF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #8E8E93;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #C7C7CC;
}

/* 一键清空 */
.clear-all-section {
  padding: 20rpx;
  margin-top: 20rpx;
}

.clear-all-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFEBE9 0%, #FFE5E0 100%);
  border: 2rpx solid #FFD5CF;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.clear-all-btn:active {
  transform: scale(0.98);
}

.clear-all-icon {
  font-size: 32rpx;
  color: #FF3B30;
  font-weight: bold;
}

.clear-all-text {
  font-size: 28rpx;
  color: #FF3B30;
  font-weight: 600;
}

/* 工具类 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
