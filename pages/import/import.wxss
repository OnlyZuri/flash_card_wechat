/* 导入页面 - Apple Design */

.container {
  min-height: 100vh;
  background-color: #F2F2F7;
  padding-bottom: 220rpx;
}

/* 区块 */
.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  padding: 16rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.section-count {
  font-size: 28rpx;
  color: #8E8E93;
}

/* 文件类型选择 */
.file-types {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.file-type-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.file-type-card:active {
  transform: scale(0.96);
}

.file-type-card.active {
  border-color: #007AFF;
  background-color: #F0F8FF;
}

.file-type-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.file-type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.file-type-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

/* 信息卡片 */
.info-card {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 20rpx;
  padding: 28rpx;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.info-content {
  flex: 1;
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1976D2;
  margin-bottom: 8rpx;
}

.info-desc {
  font-size: 26rpx;
  color: #42A5F5;
  line-height: 1.5;
}

/* 预览卡片 */
.preview-card {
  padding: 0;
  overflow: hidden;
}

.preview-scroll {
  max-height: 500rpx;
}

.preview-list {
  border-bottom: 1rpx solid #E5E5EA;
}

.preview-header {
  display: flex;
  background-color: #F9F9F9;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.preview-col {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #8E8E93;
}

.preview-item {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #E5E5EA;
}

.preview-item:last-child {
  border-bottom: none;
}

.tags-col {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 4rpx;
}

.tag-mini {
  display: inline-block;
  background-color: #E3F2FD;
  color: #007AFF;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

/* 选项卡片 */
.option-card {
  padding: 0;
}

.option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
}

.option-label {
  font-size: 30rpx;
  color: #1C1C1E;
}

.option-picker {
  flex: 1;
  text-align: right;
}

.option-value {
  font-size: 30rpx;
  color: #007AFF;
  display: inline-flex;
  align-items: center;
  font-weight: 500;
}

.arrow {
  font-size: 36rpx;
  margin-left: 8rpx;
}

/* 操作区域 */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 50rpx;
}

.btn-select,
.btn-import,
.btn-template {
  padding: 28rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-select {
  background-color: #F2F2F7;
  color: #1C1C1E;
}

.btn-import {
  background: linear-gradient(135deg, #007AFF 0%, #0A5ED4 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

.btn-template {
  background-color: #FFFFFF;
  color: #007AFF;
  border: 2rpx solid #007AFF;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-select:active,
.btn-import:active,
.btn-template:active {
  opacity: 0.7;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 32rpx;
}

/* 提示区域 */
.tip-section {
  padding: 0 24rpx;
}

.tip-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 20rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #3A3A3C;
  line-height: 1.6;
}
