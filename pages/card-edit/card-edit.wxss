/* 添加/编辑卡片页面 - 重新设计 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F6FA 0%, #E8EAF0 100%);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  position: relative;
}

/* 滚动内容区 */
.form-scroll {
  height: 100vh;
}

.form-content {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

/* 输入卡片 */
.input-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.question-icon {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.answer-icon {
  background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%);
}

.tag-icon {
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
}

.header-info {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 4rpx;
}

.card-desc {
  font-size: 24rpx;
  color: #8E8E93;
}

.input-wrapper {
  background: #F8F9FA;
  border-radius: 16rpx;
  overflow: hidden;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #1C1C1E;
  background: transparent;
  border: none;
  box-sizing: border-box;
  white-space: pre-wrap;
}

.form-textarea:focus {
  background: #FFFFFF;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  font-size: 30rpx;
  color: #1C1C1E;
  background: transparent;
  border: none;
}

.form-input:focus {
  background: #FFFFFF;
}

.placeholder {
  color: #B5B5BF;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #E8F4FD 0%, #F0F7FF 100%);
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #D0E3F5;
  transition: all 0.2s;
}

.tag-item:active {
  transform: scale(0.95);
}

.tag-text {
  font-size: 26rpx;
  color: #007AFF;
  font-weight: 500;
}

.tag-remove {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #8E8E93;
  padding: 4rpx;
}

.tag-remove:active {
  color: #FF3B30;
}

/* 信息卡片 */
.info-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-label {
  font-size: 24rpx;
  color: #8E8E93;
}

.info-value {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.info-value-level {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  text-align: center;
}

/* 底部占位 */
.bottom-placeholder {
  height: 40rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.delete-btn {
  background: #FFFFFF;
  color: #FF3B30;
  border: 2rpx solid #FFD0D0;
  flex-shrink: 0;
}

.delete-btn:active {
  background: #FFF5F5;
  transform: scale(0.96);
}

.save-btn {
  flex: 1;
  background: linear-gradient(135deg, #007AFF 0%, #0A5ED4 100%);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(0, 122, 255, 0.35);
}

.save-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.25);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 30rpx;
}
