/* 学习页面 - Apple Design */

.study-container {
  min-height: 100vh;
  background-color: #F2F2F7;
  padding-bottom: 40rpx;
}

/* 头部 */
.study-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
}

.progress-info {
  display: flex;
  align-items: center;
  flex: 1;
  margin-right: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: #E5E5EA;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #007AFF 0%, #5AC8FA 100%);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-left: 16rpx;
  min-width: 80rpx;
  text-align: right;
}

.close-btn {
  font-size: 40rpx;
  color: #8E8E93;
  padding: 10rpx;
  line-height: 1;
}

/* 退出按钮 */
.exit-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  background-color: #FFF5F5;
  border-radius: 20rpx;
  border: 1rpx solid #FFD5D5;
}

.exit-icon {
  font-size: 28rpx;
  color: #FF3B30;
}

.exit-text {
  font-size: 26rpx;
  color: #FF3B30;
  font-weight: 500;
}

/* 卡片区域 */
.card-area {
  padding: 32rpx;
  perspective: 2000rpx;
}

.flashcard {
  width: 100%;
  height: 680rpx;
  cursor: pointer;
}

.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s;
  transform-style: preserve-3d;
}

.flashcard.flipped .card-inner {
  transform: rotateY(180deg);
}

.card-front,
.card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  background-color: #FFFFFF;
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.card-back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, #FFFFFF 0%, #F8FBFF 100%);
}

.card-label {
  font-size: 26rpx;
  color: #8E8E93;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.card-content {
  flex: 1;
  font-size: 36rpx;
  color: #1C1C1E;
  line-height: 1.8;
  overflow-y: auto;
  font-weight: 500;
}

.card-content.answer {
  color: #1C1C1E;
  white-space: pre-wrap;
}

.card-tags {
  margin-top: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.flip-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid #E5E5EA;
}

.flip-icon {
  font-size: 28rpx;
}

.flip-hint text {
  font-size: 26rpx;
  color: #8E8E93;
}

/* 评分区域 */
.rating-area {
  padding: 0 32rpx;
  opacity: 0;
  visibility: hidden;
  transform: translateY(30rpx);
  transition: all 0.3s ease;
}

.rating-area.show {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.rating-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 24rpx;
}

.rating-buttons {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.rating-btn {
  padding: 28rpx 16rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
}

.rating-btn:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.rating-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.rating-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  padding: 20rpx 36rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.action-btn.skip {
  color: #8E8E93;
}

.action-btn.favorite {
  color: #FF9500;
}

.action-btn:active {
  opacity: 0.7;
}

/* 完成状态 */
.complete-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
}

.complete-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1C1C1E;
  margin-bottom: 16rpx;
}

.complete-desc {
  font-size: 30rpx;
  color: #8E8E93;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.complete-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-home,
.btn-browse {
  padding: 24rpx 48rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-home {
  background: linear-gradient(135deg, #007AFF 0%, #0A5ED4 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.3);
}

.btn-browse {
  background-color: #FFFFFF;
  color: #007AFF;
  border: 2rpx solid #007AFF;
}

/* 学习统计 */
.stats-container {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.stats-icon {
  font-size: 72rpx;
  margin-right: 20rpx;
}

.stats-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #007AFF;
}

.stats-summary {
  display: flex;
  align-items: center;
  gap: 60rpx;
  margin-bottom: 32rpx;
  padding: 36rpx 60rpx;
  background: linear-gradient(135deg, #007AFF 0%, #5AC8FA 100%);
  border-radius: 24rpx;
  color: #fff;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.summary-value {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: rgba(255, 255, 255, 0.3);
}

.stats-detail {
  width: 100%;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 28rpx;
  text-align: center;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-info {
  display: flex;
  align-items: center;
  width: 120rpx;
}

.detail-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.detail-label {
  font-size: 28rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.detail-bar-bg {
  flex: 1;
  height: 14rpx;
  background-color: #E5E5EA;
  border-radius: 7rpx;
  overflow: hidden;
}

.detail-bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

.detail-count {
  width: 70rpx;
  text-align: right;
  font-size: 28rpx;
  color: #8E8E93;
  font-weight: 500;
}

.stats-tips {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid #FFD5D5;
}

.tips-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tips-text {
  font-size: 28rpx;
  color: #E53935;
  font-weight: 500;
}

/* 底部安全区 */
.bottom-safe {
  height: 40rpx;
}
