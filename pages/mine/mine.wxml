<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo ? userInfo.avatarUrl : '/images/avatar.png'}}" mode="aspectFill"></image>
      <view class="user-details">
        <text class="user-name">{{userInfo ? userInfo.nickName : userName}}</text>
        <input class="user-desc" value="{{signature || '每天进步一点点'}}" bindblur="editSignature" placeholder="每天进步一点点" />
      </view>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{stats.continuousDays}}</text>
        <text class="stat-label">连续学习</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.todayCount}}</text>
        <text class="stat-label">今日学习</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{stats.totalCount}}</text>
        <text class="stat-label">总学习数</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card card">
      <view class="menu-item" bindtap="goStats">
        <text class="menu-icon">📊</text>
        <text class="menu-text">学习统计</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goExport">
        <text class="menu-icon">📤</text>
        <text class="menu-text">导出数据</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goImport">
        <text class="menu-icon">📥</text>
        <text class="menu-text">导入数据</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goTrash">
        <text class="menu-icon">🗑️</text>
        <text class="menu-text">回收站</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-card card">
      <view class="menu-item" bindtap="goSettings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="showAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 导出选择弹窗 -->
  <view class="export-modal {{showExportModal ? 'show' : ''}}" wx:if="{{showExportModal}}">
    <view class="export-mask" bindtap="cancelExport"></view>
    <view class="export-content">
      <view class="export-title">选择导出范围</view>
      <view class="export-options">
        <view class="export-option {{exportType === 'all' ? 'active' : ''}}" bindtap="selectExportType" data-type="all">
          <text class="option-icon">📚</text>
          <view class="option-info">
            <text class="option-name">全部卡片</text>
            <text class="option-desc">导出所有 {{totalCount}} 张卡片</text>
          </view>
          <view class="radio {{exportType === 'all' ? 'checked' : ''}}"></view>
        </view>
        <view class="export-option {{exportType === 'favorite' ? 'active' : ''}}" bindtap="selectExportType" data-type="favorite">
          <text class="option-icon">⭐</text>
          <view class="option-info">
            <text class="option-name">收藏的卡片</text>
            <text class="option-desc">导出 {{favoriteCount}} 张收藏卡片</text>
          </view>
          <view class="radio {{exportType === 'favorite' ? 'checked' : ''}}"></view>
        </view>
        <view class="export-option {{exportType === 'review' ? 'active' : ''}}" bindtap="selectExportType" data-type="review">
          <text class="option-icon">📖</text>
          <view class="option-info">
            <text class="option-name">今日可学习</text>
            <text class="option-desc">导出 {{reviewCount}} 张到期卡片</text>
          </view>
          <view class="radio {{exportType === 'review' ? 'checked' : ''}}"></view>
        </view>
      </view>
      <view class="export-actions">
        <view class="export-btn cancel" bindtap="cancelExport">取消</view>
        <view class="export-btn confirm" bindtap="confirmExport">导出</view>
      </view>
    </view>
  </view>
</view>
