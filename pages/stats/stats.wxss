.container {
  min-height: 100vh;
  background-color: #F2F2F7;
  padding-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1C1C1E;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid #007AFF;
}

/* 概览卡片 */
.overview-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #007AFF 0%, #5AC8FA 100%);
  color: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.3);
}

.overview-header {
  margin-bottom: 28rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: 600;
  opacity: 0.95;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.15);
  padding: 24rpx;
  border-radius: 16rpx;
}

.overview-value {
  font-size: 44rpx;
  font-weight: bold;
  line-height: 1;
}

.overview-label {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 12rpx;
}

/* 区块卡片 */
.section-card {
  margin: 24rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 掌握程度列表 */
.level-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.level-item {
  display: flex;
  flex-direction: column;
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.level-info {
  display: flex;
  align-items: center;
}

.level-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.level-label {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
}

.level-count {
  font-size: 28rpx;
  color: #8E8E93;
  font-weight: 600;
}

.level-bar-bg {
  height: 14rpx;
  background-color: #E5E5EA;
  border-radius: 7rpx;
  overflow: hidden;
}

.level-bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

/* 状态网格 */
.status-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 24rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.status-item:active {
  transform: scale(0.96);
}

.status-item.overdue {
  background: linear-gradient(135deg, #FFE5E5 0%, #FFF0F0 100%);
  border: 1rpx solid #FFD0D0;
}

.status-item.due {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFF9F0 100%);
  border: 1rpx solid #FFE0B5;
}

.status-item.scheduled {
  background: linear-gradient(135deg, #E8F4FD 0%, #F0F8FF 100%);
  border: 1rpx solid #B3D9FF;
}

.status-item.new {
  background: linear-gradient(135deg, #E8F8ED 0%, #F0FFF5 100%);
  border: 1rpx solid #B8E6C8;
}

.status-value {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1;
  margin-bottom: 10rpx;
}

.status-item.overdue .status-value {
  color: #FF3B30;
}

.status-item.due .status-value {
  color: #FF9500;
}

.status-item.scheduled .status-value {
  color: #007AFF;
}

.status-item.new .status-value {
  color: #34C759;
}

.status-label {
  font-size: 26rpx;
  color: #636366;
  font-weight: 500;
  text-align: center;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #E8F4FD 0%, #F0F8FF 100%);
  padding: 14rpx 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid #B3D9FF;
  transition: all 0.2s;
}

.tag-item:active {
  transform: scale(0.95);
}

.tag-name {
  font-size: 28rpx;
  color: #007AFF;
  font-weight: 600;
  margin-right: 12rpx;
}

.tag-count {
  font-size: 26rpx;
  color: rgba(0, 122, 255, 0.7);
  font-weight: 600;
  background-color: rgba(0, 122, 255, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 学习记录列表 */
.log-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.log-item {
  padding: 24rpx;
  background-color: #F9F9FB;
  border-radius: 16rpx;
  border: 1rpx solid #E5E5EA;
}

.log-question {
  font-size: 30rpx;
  color: #1C1C1E;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.log-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.log-level {
  font-size: 26rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.05);
}

.log-date {
  font-size: 26rpx;
  color: #8E8E93;
  font-weight: 500;
}
